# ─── Flask ────────────────────────────────────────────────────────────
# SECRET_KEY MUST be >= 32 chars. Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-long-string-at-least-32-chars
FLASK_DEBUG=0

# Session cookie security — set SESSION_COOKIE_SECURE=true once served over HTTPS.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_NAME=ain_sess

# ─── Database (Railway provides DATABASE_URL automatically) ───────────
DATABASE_URL=postgresql://user:password@host:port/dbname
DB_HOST=caboose.proxy.rlwy.net
DB_PORT=21778
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your-password-here

# ─── Master V integration ────────────────────────────────────────────
MASTER_V_TOKEN=your-master-v-token
DISABLE_SYNC=false

# ─── First-run admin (FORCE a password change immediately) ────────────
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe1!
DEFAULT_ADMIN_EMAIL=admin@example.com

# ─── Mailer — required for forgot-password ────────────────────────────
# OPTION 1 (recommended on Railway/Fly/Vercel — they block SMTP):
# Resend HTTPS API. Sign up at resend.com, generate an API key.
RESEND_API_KEY=

# OPTION 2: SMTP fallback (Gmail, Brevo, etc.). Ignored if RESEND_API_KEY set.
# Leave SMTP_USER empty to disable outbound mail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=no-reply@ain-realestate.local
MAIL_FROM_NAME=Ain Real Estate

# Password-reset link TTL (minutes) and the public base URL for links.
PASSWORD_RESET_TTL_MINUTES=30
APP_BASE_URL=https://your-domain.example

# ─── App port (Railway provides PORT automatically) ───────────────────
PORT=8080
